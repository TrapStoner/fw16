---
import config from 'virtual:starlight/user-config';

const ghLink = config.social?.find((l) => l.href.includes('github.com'));
const otherLinks = config.social?.filter((l) => !l.href.includes('github.com')) ?? [];

let stars = 0;
let forks = 0;
let repoSlug = '';

if (ghLink) {
  const match = ghLink.href.match(/github\.com\/([^/?#]+\/[^/?#]+)/);
  repoSlug = match?.[1] ?? '';

  if (repoSlug) {
    try {
      const res = await fetch(`https://api.github.com/repos/${repoSlug}`, {
        headers: { Accept: 'application/vnd.github.v3+json' },
      });
      if (res.ok) {
        const data = await res.json();
        stars = data.stargazers_count ?? 0;
        forks = data.forks_count ?? 0;
      }
    } catch {}
  }
}
---

{
  ghLink && repoSlug && (
    <a
      href={ghLink.href}
      class="gh-widget"
      target="_blank"
      rel="noopener noreferrer"
      data-repo={repoSlug}
    >
      <svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
        </svg>
      <span class="gh-name">{repoSlug}</span>
      <span class="gh-divider" aria-hidden="true" />
      <span class="gh-stat" data-gh="stars">
        <svg aria-hidden="true" width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
        </svg>
        <span>{stars.toLocaleString()}</span>
      </span>
      <span class="gh-divider" aria-hidden="true" />
      <span class="gh-stat" data-gh="forks">
        <svg aria-hidden="true" width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
          <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z" />
        </svg>
        <span>{forks.toLocaleString()}</span>
      </span>
    </a>
  )
}

{otherLinks.map(({ label, href }) => (
  <a {href} rel="me" class="sl-flex other-link">
    <span class="sr-only">{label}</span>
  </a>
))}

<script>
  const widget = document.querySelector<HTMLAnchorElement>('.gh-widget[data-repo]');
  if (widget) {
    const repo = widget.dataset.repo;
    fetch(`https://api.github.com/repos/${repo}`, {
      headers: { Accept: 'application/vnd.github.v3+json' },
    })
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (!data) return;
        const starsEl = widget.querySelector('[data-gh="stars"] span');
        const forksEl = widget.querySelector('[data-gh="forks"] span');
        if (starsEl) starsEl.textContent = (data.stargazers_count ?? 0).toLocaleString();
        if (forksEl) forksEl.textContent = (data.forks_count ?? 0).toLocaleString();
      })
      .catch(() => {});
  }
</script>

<style>
  .gh-widget {
    display: flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.3em 0.65em;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 35%, transparent);
    background: color-mix(in srgb, var(--sl-color-accent) 7%, transparent);
    color: var(--sl-color-text-accent);
    text-decoration: none;
    font-size: 0.75rem;
    font-family: var(--sl-font, system-ui, sans-serif);
    white-space: nowrap;
    line-height: 1;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .gh-widget:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 60%, transparent);
    color: var(--sl-color-white);
  }
  .gh-widget svg {
    display: block;
    flex-shrink: 0;
  }
  .gh-name {
    font-weight: 600;
  }
  .gh-divider {
    display: block;
    width: 1px;
    height: 0.9em;
    background: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    flex-shrink: 0;
  }
  .gh-stat {
    display: flex;
    align-items: center;
    gap: 0.25em;
    opacity: 0.85;
  }
  .other-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }
  .other-link:hover {
    color: var(--sl-color-white);
  }
</style>
